{
  "log": {
    "level": "info"
  },
  "dns": {
    "servers": [
      {
        "tag": "dns-direct",
        "address": "223.5.5.5",
        "detour": "DIRECT"
      },
      {
        "tag": "dns-block",
        "address": "rcode://success"
      },
      {
        "tag": "dns-fakeip",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15"
      },
      {
        "tag": "dns-remote",
        "address": "https://1.1.1.1/dns-query",
        "detour": "节点选择"
      }
    ],
    "rules": [
      {
        "rule_set": [
          "advertising"
        ],
        "server": "dns-block"
      },
      {
        "rule_set": [
          "geosite-cn",
          "geoip-cn"
        ],
        "server": "dns-direct"
      },
      {
        "rule_set": [
          "youtube",
          "telegram",
          "openai"
        ],
        "server": "dns-fakeip"
      }
    ],
    "final": "dns-fakeip",
    "strategy": "prefer_ipv4"
  },
  "inbounds": [
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 7890,
      "sniff": true,
      "sniff_override_destination": true,
      "set_system_proxy": false
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "rule_set": [
      {
        "type": "remote",
        "tag": "youtube",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-youtube.srs",
        "update_interval": "24h"
      },
      {
        "type": "remote",
        "tag": "telegram",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-telegram.srs",
        "update_interval": "24h"
      },
      {
        "type": "remote",
        "tag": "openai",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-openai.srs",
        "update_interval": "24h"
      },
      {
        "type": "remote",
        "tag": "geosite-cn",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-cn.srs",
        "update_interval": "24h"
      },
      {
        "type": "remote",
        "tag": "geoip-cn",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-cn.srs",
        "update_interval": "24h"
      },
      {
        "type": "remote",
        "tag": "advertising",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-ads-all.srs",
        "update_interval": "24h"
      }
    ],
    "rules": [
      {
        "ip_is_private": true,
        "action": "route",
        "outbound": "DIRECT"
      },
      {
        "rule_set": [
          "advertising"
        ],
        "action": "route",
        "outbound": "REJECT"
      },
      {
        "rule_set": [
          "openai"
        ],
        "action": "route",
        "outbound": "AI分流"
      },
      {
        "rule_set": [
          "youtube"
        ],
        "action": "route",
        "outbound": "YouTube分流"
      },
      {
        "rule_set": [
          "telegram"
        ],
        "action": "route",
        "outbound": "Telegram分流"
      },
      {
        "rule_set": [
          "geosite-cn",
          "geoip-cn"
        ],
        "action": "route",
        "outbound": "DIRECT"
      }
    ],
    "final": "节点选择"
  },
  "outbounds": [
    {
      "type": "selector",
      "tag": "节点选择",
      "outbounds": [
        "自动选择",
        "DIRECT"
      ],
      "default": "自动选择"
    },
    {
      "type": "selector",
      "tag": "YouTube分流",
      "outbounds": [
        "节点选择",
        "DIRECT"
      ],
      "default": "节点选择"
    },
    {
      "type": "selector",
      "tag": "Telegram分流",
      "outbounds": [
        "节点选择",
        "DIRECT"
      ],
      "default": "节点选择"
    },
    {
      "type": "selector",
      "tag": "AI分流",
      "outbounds": [
        "节点选择",
        "DIRECT"
      ],
      "default": "节点选择"
    },
    {
      "type": "urltest",
      "tag": "自动选择",
      "outbounds": [
        "DIRECT"
      ],
      "url": "https://cp.cloudflare.com/generate_204",
      "interval": "10m",
      "tolerance": 100
    },
    {
      "type": "direct",
      "tag": "DIRECT"
    },
    {
      "type": "block",
      "tag": "REJECT"
    }
  ],
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "cache.db",
      "cache_id": "sui-sub-template"
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090"
    }
  }
}
